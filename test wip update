// ══════════════════════════════════════════
// GAME STATE
// ══════════════════════════════════════════
let state = {};

function initState() {
  state = {
    q: 0,
    lives: 3,
    skips: 5,
    score: 0,
    locked: false,
    wcSelected: new Set()
  };
}

// ══════════════════════════════════════════
// HELPERS
// ══════════════════════════════════════════
function showScreen(id) {
  document.querySelectorAll('.screen').forEach(s => s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
}

function showOverlay(id) {
  document.querySelectorAll('.overlay').forEach(o => o.classList.remove('show'));
  document.getElementById(id).classList.add('show');
}

function hideOverlays() {
  document.querySelectorAll('.overlay').forEach(o => o.classList.remove('show'));
}

function buildHUD() {
  // Hearts
  const hh = document.getElementById('hud-hearts');
  hh.innerHTML = '';
  for (let i = 0; i < 3; i++) {
    const h = document.createElement('span');
    h.className = 'heart' + (i >= state.lives ? ' dead' : '');
    h.textContent = '❤️';
    hh.appendChild(h);
  }
  // Skips
  const hs = document.getElementById('hud-skips');
  hs.innerHTML = '';
  for (let i = 0; i < 5; i++) {
    const d = document.createElement('div');
    d.className = 'skip-dot' + (i < state.skips ? ' on' : '');
    d.textContent = '→';
    if (i < state.skips) d.addEventListener('click', () => useSkip());
    hs.appendChild(d);
  }
  document.getElementById('hud-qnum').textContent = `Q.${state.q + 1}`;
  document.getElementById('hud-bar').style.width = `${(state.q / QUESTIONS.length) * 100}%`;
  document.getElementById('hud-score').textContent = `${state.score} PTS`;
}

function useSkip() {
  if (state.locked || state.skips <= 0) return;
  state.skips--;
  state.q++;
  if (state.q >= QUESTIONS.length) { winGame(); return; }
  renderQuestion();
}

function showToast() {
  const t = document.getElementById('toast');
  t.classList.add('show');
  setTimeout(() => t.classList.remove('show'), 900);
}

function loseLife() {
  state.lives--;
  buildHUD();
  showToast();
  // Screen shake
  document.getElementById('s-game').style.animation = 'none';
  setTimeout(() => {
    document.getElementById('s-game').style.animation = '';
  }, 10);
  if (state.lives <= 0) {
    setTimeout(() => gameOver(), 800);
  }
}

function nextQuestion(delay = 800) {
  setTimeout(() => {
    state.q++;
    if (state.q >= QUESTIONS.length) { winGame(); return; }
    renderQuestion();
  }, delay);
}

function gameOver() {
  document.getElementById('go-q').textContent = state.q + 1;
  document.getElementById('go-stats').innerHTML = `
    <div class="ov-stat"><div class="ov-stat-val">${state.score}</div><div class="ov-stat-lbl">POINTS</div></div>
    <div class="ov-stat"><div class="ov-stat-val">${state.q}</div><div class="ov-stat-lbl">QUESTIONS</div></div>
  `;
  showOverlay('ov-go');
}

function winGame() {
  spawnConfetti();
  const rank = state.score >= 1800 ? 'CAPITAINE-COMMANDANT' :
               state.score >= 1400 ? 'CAPITAINE' :
               state.score >= 1000 ? 'VICE-CAPITAINE' :
               state.score >= 600 ? 'SHINIGAMI' : 'STAGIAIRE';
  document.getElementById('win-stats').innerHTML = `
    <div class="ov-stat"><div class="ov-stat-val">${state.score}</div><div class="ov-stat-lbl">POINTS</div></div>
    <div class="ov-stat"><div class="ov-stat-val">${state.skips}</div><div class="ov-stat-lbl">SKIPS RESTANTS</div></div>
  `;
  document.getElementById('win-rank').textContent = rank;
  showOverlay('ov-win');
}

function spawnConfetti() {
  const colors = ['#cc0000','#f0c000','#1144dd','#00bb44','#8800cc','#ffffff'];
  for (let i = 0; i < 80; i++) {
    const el = document.createElement('div');
    el.className = 'confetti-piece';
    el.style.cssText = `
      left:${Math.random()*100}vw;
      top:0;
      background:${colors[Math.floor(Math.random()*colors.length)]};
      animation-duration:${Math.random()*2+1.5}s;
      animation-delay:${Math.random()*0.5}s;
      width:${Math.random()*10+4}px;
      height:${Math.random()*10+4}px;
      transform:rotate(${Math.random()*360}deg);
    `;
    document.body.appendChild(el);
    setTimeout(() => el.remove(), 4000);
  }
}

// ══════════════════════════════════════════
// RENDER QUESTION
// ══════════════════════════════════════════
function renderQuestion() {
  state.locked = false;
  state.wcSelected = new Set();
  buildHUD();

  const q = QUESTIONS[state.q];
  document.getElementById('q-num').textContent = String(q.id).padStart(2,'0');
  document.getElementById('comment').style.display = 'none';
  document.getElementById('special').style.display = 'none';
  document.getElementById('answers').innerHTML = '';
  document.getElementById('special').innerHTML = '';

  // Question text
  if (q.type === 'secret_word') {
    const word = q.secretWord;
    const raw = q.text;
    const idx = raw.indexOf(word);
    const el = document.getElementById('q-text');
    if (idx >= 0) {
      el.innerHTML =
        raw.slice(0, idx) +
        `<span class="q-secret" id="secret-word">${word}</span>` +
        raw.slice(idx + word.length);
    } else {
      el.textContent = raw;
    }
    document.getElementById('secret-word')?.addEventListener('click', () => {
      if (state.locked) return;
      correct();
    });
  } else {
    document.getElementById('q-text').textContent = q.text;
  }

  // Animate card
  const card = document.getElementById('qcard');
  card.style.animation = 'none';
  void card.offsetWidth;
  card.style.animation = 'pop 0.4s cubic-bezier(0.34,1.56,0.64,1)';

  // Render by type
  switch (q.type) {
    case 'classic': renderClassic(q); break;
    case 'slider': renderSlider(q); break;
    case 'colors': renderColors(q); break;
    case 'drag': renderDrag(q); break;
    case 'hidden': renderHidden(q); break;
    case 'word_cluster': renderWordCluster(q); break;
    case 'avoid': renderAvoid(q); break;
    case 'secret_word': break; // handled above
  }
}

// ── CLASSIC ──
function renderClassic(q) {
  const grid = document.getElementById('answers');
  q.answers.forEach((txt, i) => {
    const btn = document.createElement('button');
    btn.className = 'ans';
    btn.textContent = txt;
    btn.addEventListener('click', () => {
      if (state.locked) return;
      if (i === q.correct) { btn.classList.add('correct'); correct(); }
      else { btn.classList.add('wrong'); wrong(); }
    });
    grid.appendChild(btn);
  });
}

// ── SLIDER ──
function renderSlider(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  sp.innerHTML = `
    <div class="slider-wrap">
      <div class="slider-val" id="sl-val">${q.min}</div>
      <input type="range" class="slider-ctrl" id="sl-ctrl" min="${q.min}" max="${q.max}" step="${q.step}" value="${q.min}">
      <button class="btn-submit" id="sl-submit">CONFIRMER</button>
    </div>
  `;
  const ctrl = document.getElementById('sl-ctrl');
  const val = document.getElementById('sl-val');
  ctrl.addEventListener('input', () => val.textContent = ctrl.value);
  document.getElementById('sl-submit').addEventListener('click', () => {
    if (state.locked) return;
    if (parseInt(ctrl.value) === q.correct) correct();
    else wrong();
  });
}

// ── COLORS ──
function renderColors(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  sp.innerHTML = `<div class="color-grid" id="cg"></div>`;
  const cg = document.getElementById('cg');
  q.swatches.forEach((sw, i) => {
    const el = document.createElement('div');
    el.className = 'swatch';
    el.style.background = sw.color;
    el.textContent = sw.label;
    el.addEventListener('click', () => {
      if (state.locked) return;
      if (i === q.correct) correct();
      else wrong();
    });
    cg.appendChild(el);
  });
}

// ── DRAG ──
function renderDrag(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  let order = [...q.items].sort(() => Math.random() - 0.5);
  function buildList() {
    sp.innerHTML = `<div class="drag-list" id="dl"></div>
      <button class="btn-submit" id="drag-submit" style="margin-top:8px;width:100%">VALIDER L'ORDRE</button>`;
    const dl = document.getElementById('dl');
    order.forEach((txt, i) => {
      const item = document.createElement('div');
      item.className = 'drag-item';
      item.draggable = true;
      item.dataset.idx = i;
      item.innerHTML = `<span class="drag-handle">⠿</span>${txt}`;
      item.addEventListener('dragstart', e => {
        e.dataTransfer.setData('text/plain', i);
        item.classList.add('dragging');
      });
      item.addEventListener('dragend', () => item.classList.remove('dragging'));
      item.addEventListener('dragover', e => { e.preventDefault(); item.classList.add('over'); });
      item.addEventListener('dragleave', () => item.classList.remove('over'));
      item.addEventListener('drop', e => {
        e.preventDefault();
        item.classList.remove('over');
        const from = parseInt(e.dataTransfer.getData('text/plain'));
        const to = i;
        if (from !== to) {
          [order[from], order[to]] = [order[to], order[from]];
          buildList();
        }
      });
      dl.appendChild(item);
    });
    document.getElementById('drag-submit').addEventListener('click', () => {
      if (state.locked) return;
      if (JSON.stringify(order) === JSON.stringify(q.correctOrder)) correct();
      else wrong();
    });
  }
  buildList();
}

// ── HIDDEN ──
function renderHidden(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  sp.innerHTML = `<div class="hidden-field" id="hf"></div>`;
  const hf = document.getElementById('hf');

  const positions = [];
  function rndPos(w, h) {
    let x, y, ok;
    let tries = 0;
    do {
      ok = true;
      x = Math.random() * (hf.offsetWidth - w - 10) + 5;
      y = Math.random() * (hf.offsetHeight - h - 10) + 5;
      for (const p of positions) {
        if (Math.abs(x - p.x) < 80 && Math.abs(y - p.y) < 30) { ok = false; break; }
      }
      tries++;
    } while (!ok && tries < 50);
    positions.push({ x, y });
    return { x, y };
  }

  const allItems = [...q.decoys, q.correct_text].sort(() => Math.random() - 0.5);
  allItems.forEach(txt => {
    const el = document.createElement('div');
    el.textContent = txt;
    const isCorrect = txt === q.correct_text;
    el.className = isCorrect ? 'hidden-correct' : 'hidden-decoy';
    const p = rndPos(120, 40);
    el.style.left = p.x + 'px';
    el.style.top = p.y + 'px';
    el.addEventListener('click', () => {
      if (state.locked) return;
      if (isCorrect) correct();
      else wrong();
    });
    hf.appendChild(el);
  });
}

// ── WORD CLUSTER ──
function renderWordCluster(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  sp.innerHTML = `
    <div class="word-cluster" id="wc"></div>
    <button class="btn-submit" id="wc-submit" style="margin-top:8px;width:100%">VALIDER</button>
  `;
  const wc = document.getElementById('wc');
  q.words.forEach(w => {
    const btn = document.createElement('button');
    btn.className = 'wc-btn';
    btn.textContent = w;
    btn.addEventListener('click', () => {
      if (state.locked) return;
      if (state.wcSelected.has(w)) { state.wcSelected.delete(w); btn.classList.remove('selected'); }
      else { state.wcSelected.add(w); btn.classList.add('selected'); }
    });
    wc.appendChild(btn);
  });
  document.getElementById('wc-submit').addEventListener('click', () => {
    if (state.locked) return;
    const sel = [...state.wcSelected].sort();
    const exp = [...q.correct].sort();
    if (JSON.stringify(sel) === JSON.stringify(exp)) correct();
    else wrong();
  });
}

// ── AVOID ──
function renderAvoid(q) {
  const sp = document.getElementById('special');
  sp.style.display = 'block';
  sp.innerHTML = `<div class="avoid-field" id="af"></div>`;
  const af = document.getElementById('af');

  function rndPos(el) {
    const w = 120, h = 44;
    el.style.left = Math.random() * (af.offsetWidth - w - 10) + 5 + 'px';
    el.style.top = Math.random() * (af.offsetHeight - h - 10) + 5 + 'px';
  }

  // Target
  const target = document.createElement('button');
  target.className = 'avoid-btn target';
  target.textContent = q.targetLabel;
  rndPos(target);
  target.addEventListener('click', () => { if (!state.locked) correct(); });
  af.appendChild(target);

  // Traps — move on hover
  for (let i = 0; i < 4; i++) {
    const trap = document.createElement('button');
    trap.className = 'avoid-btn trap';
    trap.textContent = q.trapLabel;
    rndPos(trap);
    trap.addEventListener('mouseenter', () => rndPos(trap));
    trap.addEventListener('click', () => { if (!state.locked) wrong(); });
    af.appendChild(trap);
  }
}

// ══════════════════════════════════════════
// CORRECT / WRONG
// ══════════════════════════════════════════
function correct() {
  if (state.locked) return;
  state.locked = true;
  state.score += 100 + (state.lives * 10);

  const q = QUESTIONS[state.q];
  if (q.comment) {
    const c = document.getElementById('comment');
    document.getElementById('comment-text').textContent = q.comment;
    c.style.display = 'flex';
  }
  nextQuestion(q.comment ? 2000 : 600);
}

function wrong() {
  if (state.locked) return;
  state.locked = true;
  loseLife();
  if (state.lives > 0) {
    setTimeout(() => { state.locked = false; }, 900);
  }
}

// ══════════════════════════════════════════
// BUTTONS
// ══════════════════════════════════════════
document.getElementById('btn-start').addEventListener('click', () => {
  initState();
  showScreen('s-game');
  renderQuestion();
});

document.getElementById('btn-retry').addEventListener('click', () => {
  hideOverlays();
  initState();
  showScreen('s-game');
  renderQuestion();
});

document.getElementById('btn-replay').addEventListener('click', () => {
  hideOverlays();
  initState();
  showScreen('s-game');
  renderQuestion();
});
</script>
